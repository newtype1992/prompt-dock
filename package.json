{
  "name": "prompt-dock",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "tsx --test tests/backend/schema.test.ts tests/backend/subscriptions.test.ts tests/backend/team-invites.test.ts tests/extension/runtime-config.test.ts tests/extension/cloud-mappers.test.ts tests/extension/workspaces.test.ts tests/extension/invites.test.ts",
    "test:backend": "tsx --test tests/backend/schema.test.ts tests/backend/subscriptions.test.ts tests/backend/team-invites.test.ts",
    "test:extension": "tsx --test tests/extension/runtime-config.test.ts tests/extension/cloud-mappers.test.ts tests/extension/workspaces.test.ts tests/extension/invites.test.ts",
    "db:push": "supabase db push",
    "db:reset": "supabase db reset",
    "extension:dev": "vite build --watch --config extension/vite.config.ts",
    "extension:build": "vite build --config extension/vite.config.ts"
  },
  "dependencies": {
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.56.1",
    "@tailwindcss/postcss": "^4.2.2",
    "clsx": "^2.1.1",
    "next": "^15.3.0",
    "postcss": "^8.5.8",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "resend": "^4.6.0",
    "shadcn": "^4.1.0",
    "stripe": "^20.4.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.3",
    "@types/chrome": "^0.1.24",
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^5.0.0",
    "eslint": "^9.23.0",
    "eslint-config-next": "^15.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "vite": "^7.0.0"
  }
}
